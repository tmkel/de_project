uk_carbon:
  target: docker
  outputs:
    docker:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', 'postgres') }}"
      port: 5432
      user: "{{ env_var('POSTGRES_USER', 'uk_carbon_user') }}"
      pass: "{{ env_var('POSTGRES_PASSWORD', 'uk_carbon_password') }}"
      dbname: "{{ env_var('POSTGRES_DB', 'uk_carbon') }}"
      schema: public
      threads: 2