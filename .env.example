# PostgreSQL (used by both pipeline and Airflow)
POSTGRES_HOST=postgres
POSTGRES_DB=uk_carbon
POSTGRES_USER=uk_carbon_user
POSTGRES_PASSWORD=uk_carbon_password

# Airflow
AIRFLOW_UID=1000
AIRFLOW__CORE__FERNET_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# For local development (without Docker)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=uk_carbon
# DB_USER=uk_carbon_user
# DB_PASSWORD=uk_carbon_password
